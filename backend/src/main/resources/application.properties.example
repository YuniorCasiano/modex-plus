# ============================================================
# application.properties.example - Modex Monolito (desarrollo LOCAL)
# Copia este archivo como "application.properties" y ajusta
# los valores segun tu entorno local. application.properties
# esta en .gitignore y no se sube al repositorio.
# ============================================================

spring.application.name=modex-monolith
server.port=8080

# ── MongoDB - una sola base "modex_db" con varias colecciones ──
spring.data.mongodb.uri=mongodb://CAMBIAR_USUARIO:CAMBIAR_PASSWORD@localhost:27017/modex_db?authSource=admin
spring.data.mongodb.database=modex_db

# ── PostgreSQL - orders e inventory ──
spring.datasource.url=jdbc:postgresql://localhost:5432/CAMBIAR_NOMBRE_BD
spring.datasource.username=CAMBIAR_USUARIO
spring.datasource.password=CAMBIAR_PASSWORD
spring.datasource.driver-class-name=org.postgresql.Driver

# ── JPA ──
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.format_sql=true
spring.jpa.database-platform=org.hibernate.dialect.PostgreSQLDialect

# ── JWT ──
jwt.secret=CAMBIAR_POR_UNA_CLAVE_LARGA_Y_ALEATORIA_DE_MINIMO_32_CARACTERES
jwt.expiration=3600000
jwt.refresh-expiration=604800000

# ── CORS - en local permitimos todo origen ──
app.cors.allowed-origins=*

# ── Logging ──
logging.level.com.modex=DEBUG
logging.level.org.springframework.security=DEBUG

# ── Actuator ──
management.endpoints.web.exposure.include=health,metrics,info
management.endpoint.health.show-details=always

# ── Jackson ──
spring.jackson.default-property-inclusion=non_null
spring.jackson.serialization.write-dates-as-timestamps=false
